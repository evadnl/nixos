  b = "\\e[38;2;137;180;250m";
  m = "\\e[38;2;203;166;247m";
  r = "\\e[0m";

  greeting = lib.concatStringsSep "\\n" [
    "${b}          ‚Ėó‚ĖĄ‚ĖĄ‚ĖĄ       ‚Ėó‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ    ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĖ${r}"
    "${b}          ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô       ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô  ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}           ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô       ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}            ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô       ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${m}     ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėô ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ     ‚Ėü‚Ėô${r}"
    "${m}    ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėô ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô    ‚Ėü‚Ėą‚Ėą‚Ėô${r}"
    "${b}           ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĖ           ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô  ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}          ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ             ‚Ėú‚Ėą‚Ėą‚Ėõ ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}         ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ               ‚Ėú‚Ėõ ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${m}‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ                  ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėô${r}"
    "${m}‚Ėú‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ                  ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}      ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ ‚Ėü‚Ėô               ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}     ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ ‚Ėü‚Ėą‚Ėą‚Ėô             ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}    ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ  ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô           ‚ĖĚ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ${r}"
    "${m}    ‚Ėú‚Ėą‚Ėą‚Ėõ    ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${m}     ‚Ėú‚Ėõ     ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėô ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėõ${r}"
    "${b}           ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėô         ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô${r}"
    "${b}          ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô         ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô${r}"
    "${b}         ‚Ėü‚Ėą‚Ėą‚Ėą‚Ėõ  ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô         ‚Ėú‚Ėą‚Ėą‚Ėą‚Ėô${r}"
    "${b}         ‚ĖĚ‚ĖÄ‚ĖÄ‚ĖÄ    ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚Ėė         ‚ĖÄ‚ĖÄ‚ĖÄ‚Ėė${r}"
  ];

  greetScript = pkgs.writeShellScript "tuigreet-wrapper" ''
    exec ${pkgs.tuigreet}/bin/tuigreet \
      --time \
      --remember \
      --greeting "$(printf '${greeting}')" \
      --cmd Hyprland
  '';
in
{
  options.desktop.hyprland = {
    enable = lib.mkEnableOption "Hyprland desktop environment";
  };

  config = lib.mkIf cfg.enable {
    programs.hyprland.enable = true;

    security.rtkit.enable = true;

    services.pipewire = {
      enable = true;
      pulse.enable = true;
      alsa.enable = true;
    };

    services.greetd = {
      enable = true;
      settings = {
        default_session = {
          command = "${greetScript}";
          user = "greeter";
        };
      };
    };

    environment.systemPackages = with pkgs; [
      kitty
    ];
  };
}
